// Prisma schema for MY Git Analyzer (Phase 6).
// Two models: User (auth) and Analysis (saved repo analyses).
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String?    // nullable — Google-authenticated users have no password
  googleId     String?    @unique // set for users who signed in with Google
  name         String?
  avatarUrl    String?
  createdAt    DateTime   @default(now())
  analyses     Analysis[]
}

model Analysis {
  id        String   @id @default(cuid())
  // The full facts object returned by the analyze pipeline, stored as JSON.
  repoUrl   String
  repoOwner String
  repoName  String
  data      Json
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  @@index([userId])
}
