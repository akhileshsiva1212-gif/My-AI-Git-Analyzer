# ---- Server ----
PORT=5000

# ---- AI layer (provider-agnostic) ----
# Point these at your FreeModel API. Nothing about the provider is hard-coded;
# the app reads everything from here.
AI_BASE_URL=https://your-freemodel-endpoint/v1
AI_API_KEY=your-api-key-here
# Use "auto" to let FreeModel pick the model automatically.
MODEL=auto

# ---- Database ----
# SQLite: a single local file, no server to install. Prisma creates it on migrate.
DATABASE_URL="file:./dev.db"

# ---- Auth ----
JWT_SECRET=change-me-to-a-long-random-string

# ---- Google OAuth ----
# Create a free OAuth Client ID (Web application) in Google Cloud Console,
# add http://localhost:5173 as an Authorized JavaScript origin, paste it here.
# The SAME value must also go in client/.env as VITE_GOOGLE_CLIENT_ID.
GOOGLE_CLIENT_ID=your-google-oauth-client-id
