# ---- Server ----
PORT=5000

# ---- AI layer (provider-agnostic) ----
# Point these at your FreeModel API. Nothing about the provider is hard-coded;
# the app reads everything from here.
AI_BASE_URL=https://your-freemodel-endpoint/v1
AI_API_KEY=your-api-key-here
# Use "auto" to let FreeModel pick the model automatically.
MODEL=auto

# ---- Database (used in Phase 6) ----
DATABASE_URL=postgresql://user:password@localhost:5432/git_analyzer

# ---- Auth (used in Phase 6) ----
JWT_SECRET=change-me-to-a-long-random-string
